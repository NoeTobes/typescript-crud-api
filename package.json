{
  "name": "typescript-crud-api",
  "version": "1.0.0",
  "description": "TypeScript CRUD API with Node.js, Express, MySQL and lab frontend",
  "main": "dist/server.js",
  "scripts": {
    "start:dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "start:frontend": "http-server . -p 5500 -c-1",
    "start:all": "powershell -ExecutionPolicy Bypass -File ./start-all.ps1",
    "stop:all": "powershell -ExecutionPolicy Bypass -File ./stop-all.ps1",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.3",
    "rootpath": "^0.1.2",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "http-server": "^14.1.1",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
